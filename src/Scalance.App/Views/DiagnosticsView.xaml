<UserControl x:Class="Scalance.App.Views.DiagnosticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <TextBlock Text="設備：" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SelectedDeviceName, FallbackValue=(無)}"
                       FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Grid.Row="1" Margin="0,8,0,0" Opacity="0.7"
                   Text="Ping — 手冊 sec 5.1.8 p. 86：ping { &lt;ip&gt; | fqdn-name &lt;fqdn&gt; } [size 0-2080] [count 1-10] [timeout 1-100]"/>

        <Grid Grid.Row="2" Margin="0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="主機：" VerticalAlignment="Center"/>
            <TextBox   Grid.Column="1" Text="{Binding PingHost, UpdateSourceTrigger=PropertyChanged}"
                       ToolTip="IPv4 位址或 FQDN（≤100 字元）"/>
            <TextBlock Grid.Column="2" Text="Size：" Margin="12,0,4,0" VerticalAlignment="Center"/>
            <TextBox   Grid.Column="3" Text="{Binding PingSize, UpdateSourceTrigger=PropertyChanged}"
                       ToolTip="bytes 0-2080；留空=32"/>
            <TextBlock Grid.Column="4" Text="Count：" Margin="12,0,4,0" VerticalAlignment="Center"/>
            <TextBox   Grid.Column="5" Text="{Binding PingCount, UpdateSourceTrigger=PropertyChanged}"
                       ToolTip="1-10"/>
            <TextBlock Grid.Column="6" Text="Timeout：" Margin="12,0,4,0" VerticalAlignment="Center"/>
            <TextBox   Grid.Column="7" Text="{Binding PingTimeout, UpdateSourceTrigger=PropertyChanged}"
                       ToolTip="秒；1-100"/>
            <Button    Grid.Column="8" Content="Ping" Command="{Binding PingCommand}"
                       Margin="12,0,0,0" Padding="14,2"/>
        </Grid>

        <!-- Traceroute — manual sec 5.1.10 p. 88 (IPv4/IPv6 literal only) -->
        <StackPanel Orientation="Horizontal" Grid.Row="3" Margin="0,8">
            <TextBlock Text="Traceroute 主機：" VerticalAlignment="Center"/>
            <TextBox Text="{Binding TraceHost, UpdateSourceTrigger=PropertyChanged}" Width="260"
                     ToolTip="IPv4 或 IPv6 字面值（手冊不接受 FQDN）"/>
            <Button Content="Traceroute" Command="{Binding TraceRouteCommand}"
                    Margin="12,0,0,0" Padding="14,2"/>
        </StackPanel>

        <!-- Restart — manual sec 5.3.1 p. 130-131. Gated by confirmation checkbox. -->
        <StackPanel Grid.Row="4" Margin="0,12,0,0">
            <Border Padding="6" BorderBrush="#D32F2F" BorderThickness="1" Background="#FFEBEE">
                <StackPanel Orientation="Horizontal">
                    <CheckBox Content="我確認要重啟裝置（restart 立即生效）"
                              IsChecked="{Binding RestartConfirmed}"
                              VerticalAlignment="Center" FontWeight="Bold"/>
                    <Separator Width="12"/>
                    <Button Content="restart" Command="{Binding RestartCurrentCommand}"
                            Padding="10,2" ToolTip="以目前設定重啟（非破壞性）"/>
                    <Button Content="restart memory" Command="{Binding RestartMemoryCommand}"
                            Margin="6,0,0,0" Padding="10,2"
                            ToolTip="除 IP/hostname/user 等保留項外，其餘 factory reset"/>
                    <Button Content="restart factory" Command="{Binding RestartFactoryCommand}"
                            Margin="6,0,0,0" Padding="10,2"
                            ToolTip="完全 factory reset（含 IP 與帳密）— 會失去連線"/>
                </StackPanel>
            </Border>

            <!-- Scheduled restart — manual sec 5.3.2.3-4 pp. 133-134 -->
            <Border Margin="0,6,0,0" Padding="6" BorderBrush="#BDBDBD" BorderThickness="1" Background="#FAFAFA">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="排程重啟（秒，300-86400）：" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding ScheduleSecondsText, UpdateSourceTrigger=PropertyChanged}"
                             Width="90" ToolTip="5 分 ~ 24 小時；送出 schedule restart-timer N force"/>
                    <Button Content="排程重啟" Command="{Binding ScheduleRestartCommand}"
                            Margin="8,0,0,0" Padding="10,2"/>
                    <Button Content="取消排程" Command="{Binding CancelScheduleCommand}"
                            Margin="6,0,0,0" Padding="10,2"
                            ToolTip="cancel restart-timer（手冊 sec 5.3.2.4 p. 134）"/>
                </StackPanel>
            </Border>

            <!-- Identify via LED blink — manual sec 5.5.2.5 p. 147 -->
            <Border Margin="0,6,0,0" Padding="6" BorderBrush="#BDBDBD" BorderThickness="1" Background="#FAFAFA">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="LED 閃爍識別（秒，5-60）：" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding BlinkSecondsText, UpdateSourceTrigger=PropertyChanged}"
                             Width="70" ToolTip="das mac own blink timeout &lt;sec&gt;（手冊 p. 147）"/>
                    <Button Content="閃爍 LED" Command="{Binding BlinkLedsCommand}"
                            Margin="8,0,0,0" Padding="10,2"
                            ToolTip="讓目前所選設備的 LED 閃爍指定秒數，方便在機櫃中找到它"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <TextBlock Grid.Row="5" Text="輸出：" Margin="0,8,0,2" FontWeight="Bold"/>

        <TextBox Grid.Row="6" Text="{Binding Output, Mode=OneWay}"
                 IsReadOnly="True" FontFamily="Consolas"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 AcceptsReturn="True" TextWrapping="NoWrap"
                 Background="#111" Foreground="#DCDCDC" Padding="6"/>

        <ProgressBar Grid.Row="7" Height="4" IsIndeterminate="{Binding IsBusy}" Margin="0,4"/>
        <StatusBar Grid.Row="8">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
