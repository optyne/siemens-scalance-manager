<UserControl x:Class="Scalance.App.Views.DiagnosticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <TextBlock Text="設備：" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SelectedDeviceName, FallbackValue=(無)}"
                       FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Grid.Row="1" Margin="0,8,0,0" Opacity="0.7"
                   Text="Ping — 手冊 sec 5.1.8 p. 86：ping { &lt;ip&gt; | fqdn-name &lt;fqdn&gt; } [size 0-2080] [count 1-10] [timeout 1-100]"/>

        <Grid Grid.Row="2" Margin="0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="主機：" VerticalAlignment="Center"/>
            <TextBox   Grid.Column="1" Text="{Binding PingHost, UpdateSourceTrigger=PropertyChanged}"
                       ToolTip="IPv4 位址或 FQDN（≤100 字元）"/>
            <TextBlock Grid.Column="2" Text="Size：" Margin="12,0,4,0" VerticalAlignment="Center"/>
            <TextBox   Grid.Column="3" Text="{Binding PingSize, UpdateSourceTrigger=PropertyChanged}"
                       ToolTip="bytes 0-2080；留空=32"/>
            <TextBlock Grid.Column="4" Text="Count：" Margin="12,0,4,0" VerticalAlignment="Center"/>
            <TextBox   Grid.Column="5" Text="{Binding PingCount, UpdateSourceTrigger=PropertyChanged}"
                       ToolTip="1-10"/>
            <TextBlock Grid.Column="6" Text="Timeout：" Margin="12,0,4,0" VerticalAlignment="Center"/>
            <TextBox   Grid.Column="7" Text="{Binding PingTimeout, UpdateSourceTrigger=PropertyChanged}"
                       ToolTip="秒；1-100"/>
            <Button    Grid.Column="8" Content="Ping" Command="{Binding PingCommand}"
                       Margin="12,0,0,0" Padding="14,2"/>
        </Grid>

        <!-- Traceroute — manual sec 5.1.10 p. 88 (IPv4/IPv6 literal only) -->
        <StackPanel Orientation="Horizontal" Grid.Row="3" Margin="0,8">
            <TextBlock Text="Traceroute 主機：" VerticalAlignment="Center"/>
            <TextBox Text="{Binding TraceHost, UpdateSourceTrigger=PropertyChanged}" Width="260"
                     ToolTip="IPv4 或 IPv6 字面值（手冊不接受 FQDN）"/>
            <Button Content="Traceroute" Command="{Binding TraceRouteCommand}"
                    Margin="12,0,0,0" Padding="14,2"/>
        </StackPanel>

        <TextBlock Grid.Row="4" Text="輸出：" Margin="0,8,0,2" FontWeight="Bold"/>

        <TextBox Grid.Row="5" Text="{Binding Output, Mode=OneWay}"
                 IsReadOnly="True" FontFamily="Consolas"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 AcceptsReturn="True" TextWrapping="NoWrap"
                 Background="#111" Foreground="#DCDCDC" Padding="6"/>

        <ProgressBar Grid.Row="6" Height="4" IsIndeterminate="{Binding IsBusy}" Margin="0,4"/>
        <StatusBar Grid.Row="7">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
