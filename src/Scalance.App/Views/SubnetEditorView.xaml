<UserControl x:Class="Scalance.App.Views.SubnetEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <TextBlock Text="設備：" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SelectedDeviceName, FallbackValue=(無)}" FontWeight="Bold" VerticalAlignment="Center"/>
            <Separator Width="16"/>
            <Button Content="載入"         Command="{Binding LoadCommand}"   Margin="4,0"/>
            <Button Content="套用選取項目" Command="{Binding ApplyCommand}"  Margin="4,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Interfaces}"
                      SelectedItem="{Binding SelectedInterface}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="介面" Binding="{Binding InterfaceName}" Width="*"/>
                    <DataGridTextColumn Header="IPv4" Binding="{Binding IpAddress}"     Width="140"/>
                </DataGrid.Columns>
            </DataGrid>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                          DataContext="{Binding SelectedInterface}">
                <StackPanel Margin="12,0,0,0">
                    <TextBlock Text="介面詳細設定" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="名稱："/>
                        <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding InterfaceName, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"
                                   ToolTip="例如 vlan1 或 ethernet 0/1"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="DHCP："/>
                        <CheckBox  Grid.Row="1" Grid.Column="1" IsChecked="{Binding DhcpEnabled}" Margin="0,2"
                                   Content="透過 DHCP 取得 IP"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="IP 位址："/>
                        <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="子網遮罩："/>
                        <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding SubnetMask, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"
                                   ToolTip="例如 255.255.255.0（留空則使用前綴長度）"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="前綴長度："/>
                        <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding PrefixLength, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"
                                   ToolTip="例如 24"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="閘道："/>
                        <TextBox   Grid.Row="5" Grid.Column="1" Text="{Binding DefaultGateway, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="DNS 伺服器："/>
                        <TextBox   Grid.Row="6" Grid.Column="1" Text="{Binding DnsServersCsv, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"
                                   ToolTip="以逗號分隔，例如 8.8.8.8, 1.1.1.1"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="VLAN ID："/>
                        <TextBox   Grid.Row="7" Grid.Column="1" Text="{Binding VlanId, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <ProgressBar Grid.Row="2" Height="4" IsIndeterminate="{Binding IsBusy}" Margin="0,4"/>
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
