<UserControl x:Class="Scalance.App.Views.DeviceListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <Button Content="新增"   Command="{Binding AddCommand}"/>
            <Button Content="編輯"   Command="{Binding EditCommand}"/>
            <Button Content="刪除"   Command="{Binding DeleteCommand}"/>
            <Separator Width="16"/>
            <Button Content="測試 / 重新整理" Command="{Binding TestCommand}"/>
        </StackPanel>

        <DataGrid Grid.Row="1" Margin="0,8"
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding Selected}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="名稱"       Binding="{Binding Name}"     Width="*"/>
                <DataGridTextColumn Header="主機"       Binding="{Binding Host}"     Width="140"/>
                <DataGridTextColumn Header="型號"       Binding="{Binding ModelName}" Width="100"/>
                <DataGridTextColumn Header="韌體"       Binding="{Binding Firmware}" Width="140"/>
                <DataGridTextColumn Header="最後回應"   Binding="{Binding LastSeen}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
