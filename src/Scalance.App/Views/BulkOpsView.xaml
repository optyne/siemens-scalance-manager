<UserControl x:Class="Scalance.App.Views.BulkOpsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Scalance.App.ViewModels">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: device list with checkboxes -->
        <DockPanel Grid.Column="0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="目標設備" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="全選" Command="{Binding SelectAllCommand}" Margin="8,0,4,0" Padding="8,2"/>
                <Button Content="全不選" Command="{Binding SelectNoneCommand}" Padding="8,2"/>
                <Button Content="重載" Command="{Binding ReloadCommand}" Margin="8,0,0,0" Padding="8,2"/>
            </StackPanel>
            <ListBox ItemsSource="{Binding Devices}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:BulkDeviceRow}">
                        <DockPanel>
                            <CheckBox IsChecked="{Binding IsSelected}" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Width="110"/>
                            <TextBlock Text="{Binding Host}" Opacity="0.7" Width="110"/>
                            <TextBlock Text="{Binding ModelName}" Opacity="0.5"/>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Right: action config + results -->
        <DockPanel Grid.Column="1" Margin="12,0,0,0">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Text="批次操作" FontSize="16" FontWeight="Bold"/>
                <TextBlock Text="{Binding StatusMessage}" Opacity="0.8" TextWrapping="Wrap" Margin="0,4"/>

                <StackPanel Orientation="Horizontal" Margin="0,8">
                    <TextBlock Text="動作：" VerticalAlignment="Center"/>
                    <ComboBox Width="200" Margin="4,0"
                              ItemsSource="{Binding AvailableActions}"
                              SelectedItem="{Binding SelectedAction}"/>
                    <TextBlock Text="平行數：" Margin="16,0,4,0" VerticalAlignment="Center"/>
                    <TextBox Width="40" Text="{Binding MaxParallel}"/>
                </StackPanel>

                <!-- Password action fields -->
                <GroupBox Header="改密碼" Padding="8" Margin="0,4"
                          Visibility="{Binding SelectedAction, Converter={StaticResource EqualsConverter}, ConverterParameter=ChangeAdminPassword}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="帳號" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding AdminUsername}" Margin="0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="新密碼" VerticalAlignment="Center"/>
                        <PasswordBox Grid.Row="1" Grid.Column="1" Margin="0,2"
                                     PasswordChanged="NewPassword_PasswordChanged"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="確認密碼" VerticalAlignment="Center"/>
                        <PasswordBox Grid.Row="2" Grid.Column="1" Margin="0,2"
                                     PasswordChanged="ConfirmPassword_PasswordChanged"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="設 DNS" Padding="8" Margin="0,4"
                          Visibility="{Binding SelectedAction, Converter={StaticResource EqualsConverter}, ConverterParameter=SetDns}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="DNS 1" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Dns1}" Margin="0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="DNS 2" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding Dns2}" Margin="0,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Domain" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding DomainName}" Margin="0,2"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="新增 VLAN" Padding="8" Margin="0,4"
                          Visibility="{Binding SelectedAction, Converter={StaticResource EqualsConverter}, ConverterParameter=AddVlan}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="VLAN ID" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding VlanId}" Margin="0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="名稱" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding VlanName}" Margin="0,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Tagged Ports" VerticalAlignment="Center"
                                   ToolTip="埠號以逗號分隔，例如：1,2,3"/>
                        <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding VlanPorts}" Margin="0,2"/>
                    </Grid>
                </GroupBox>

                <Button Content="執行" Command="{Binding ApplyCommand}"
                        Padding="20,6" Margin="0,8" HorizontalAlignment="Left"/>
            </StackPanel>

            <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="False"
                      IsReadOnly="True" HeadersVisibility="Column" CanUserAddRows="False"
                      GridLinesVisibility="None" AlternatingRowBackground="#F8F8F8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="設備" Binding="{Binding DeviceName}" Width="140"/>
                    <DataGridTextColumn Header="狀態" Binding="{Binding Status}" Width="60"/>
                    <DataGridTextColumn Header="耗時" Binding="{Binding Elapsed}" Width="70"/>
                    <DataGridTextColumn Header="訊息" Binding="{Binding Message}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</UserControl>
