<Window x:Class="Scalance.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Scalance.App.Views"
        Title="Siemens SCALANCE 管理工具" Height="720" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- DryRun 狀態列 — 最頂部，醒目顏色 -->
        <Border Grid.Row="0" Padding="8,6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#FFF3E0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DryRun}" Value="False">
                            <Setter Property="Background" Value="#FFEBEE"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <ToggleButton DockPanel.Dock="Right" Margin="8,0,0,0" Padding="16,4"
                              IsChecked="{Binding DryRun, Mode=TwoWay}"
                              FontWeight="Bold">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Content" Value="🔒 DryRun 開啟 — 點此切換為實際執行"/>
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter Property="Content" Value="⚡ 實際執行中 — 點此切換回 DryRun"/>
                                    <Setter Property="Foreground" Value="#D32F2F"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
                <TextBlock VerticalAlignment="Center" FontSize="13">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="🛡️ 安全模式：所有寫入指令只會規劃並記錄，不會送到設備。"/>
                            <Setter Property="Foreground" Value="#E65100"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DryRun}" Value="False">
                                    <Setter Property="Text" Value="⚠️ 注意：寫入指令將直接送到設備執行！請確認設定無誤再套用。"/>
                                    <Setter Property="Foreground" Value="#D32F2F"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- 全域設備選取列 -->
        <Border Grid.Row="1" Background="#F5F6F8" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="目前設備：" FontWeight="Bold" VerticalAlignment="Center"/>
                <ComboBox Width="260" Margin="8,0"
                          ItemsSource="{Binding Devices.Items}"
                          DisplayMemberPath="Name"
                          SelectedItem="{Binding Devices.Selected, Mode=TwoWay}"/>
                <TextBlock VerticalAlignment="Center" Margin="8,0"
                           Text="{Binding Devices.Selected.Host, StringFormat={}({0})}"
                           Opacity="0.7"/>
                <TextBlock VerticalAlignment="Center" Margin="8,0"
                           Text="{Binding Devices.Selected.ModelName}"
                           Opacity="0.7"/>
                <Separator Width="16"/>
                <Button Content="測試連線" Command="{Binding Devices.TestCommand}"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="2">
            <TabItem Header="設備清單">
                <views:DeviceListView DataContext="{Binding Devices}"/>
            </TabItem>
            <TabItem Header="探索">
                <views:DiscoveryView DataContext="{Binding Discovery}"/>
            </TabItem>
            <TabItem Header="VLAN">
                <views:VlanEditorView DataContext="{Binding Vlan}"/>
            </TabItem>
            <TabItem Header="NTP">
                <views:NtpEditorView DataContext="{Binding Ntp}"/>
            </TabItem>
            <TabItem Header="子網 / IP">
                <views:SubnetEditorView DataContext="{Binding Subnet}"/>
            </TabItem>
            <TabItem Header="VPN">
                <views:VpnEditorView DataContext="{Binding Vpn}"/>
            </TabItem>
            <TabItem Header="防火牆">
                <views:FirewallEditorView DataContext="{Binding Firewall}"/>
            </TabItem>
            <TabItem Header="Basic Wizard">
                <views:BasicWizardView DataContext="{Binding BasicWizard}"/>
            </TabItem>
            <TabItem Header="批次設定">
                <views:BulkOpsView DataContext="{Binding BulkOps}"/>
            </TabItem>
            <TabItem Header="連線狀態">
                <views:ConnectionStatusView DataContext="{Binding ConnectionStatus}"/>
            </TabItem>
            <TabItem Header="拓撲圖">
                <views:TopologyView DataContext="{Binding Topology}"/>
            </TabItem>
        </TabControl>

        <GridSplitter Grid.Row="3" Height="4" HorizontalAlignment="Stretch" Background="#DDDDDD"/>

        <!-- 操作記錄 -->
        <DockPanel Grid.Row="4" Margin="0">
            <TextBlock DockPanel.Dock="Top" Text="操作記錄" FontWeight="Bold" Margin="8,4"/>
            <DataGrid ItemsSource="{Binding Log.Entries}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" CanUserAddRows="False"
                      GridLinesVisibility="None" AlternatingRowBackground="#F8F8F8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="時間"    Binding="{Binding TimestampDisplay}" Width="80"/>
                    <DataGridTextColumn Header="層級"    Binding="{Binding LevelDisplay}"     Width="60"/>
                    <DataGridTextColumn Header="訊息"    Binding="{Binding Message}"          Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <StatusBar Grid.Row="5">
            <StatusBarItem>
                <TextBlock Text="{Binding Log.LatestLine, FallbackValue=待命。}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
